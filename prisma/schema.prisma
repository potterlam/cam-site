generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  roomsCreated  Room[]    @relation("RoomCreator")
  roomMembers   RoomMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Room {
  id              String     @id @default(cuid())
  code            String     @unique
  creatorId       String
  gameType        GameType
  punishmentSetId String?
  maxPlayers      Int        @default(6)
  maxSpectators   Int        @default(100)
  status          RoomStatus @default(WAITING)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  creator         User         @relation("RoomCreator", fields: [creatorId], references: [id])
  members         RoomMember[]
  gameRounds      GameRound[]
}

model RoomMember {
  id        String     @id @default(cuid())
  roomId    String
  userId    String
  role      MemberRole @default(SPECTATOR)
  joinedAt  DateTime   @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model GameRound {
  id          String    @id @default(cuid())
  roomId      String
  roundNumber Int
  gameType    GameType
  result      Json?     // stores game result data
  loserId     String?
  punishment  String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

// ─── Punishment Sets ────────────────────────────────────────────────────────
// To add punishments, insert rows into this model.
// Each PunishmentSet has a name and a list of Punishment items.
model PunishmentSet {
  id          String       @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime     @default(now())

  punishments Punishment[]
}

model Punishment {
  id              String        @id @default(cuid())
  setId           String
  description     String        // e.g. "Drink a shot", "Do 10 push-ups"
  severity        Int           @default(1) // 1=mild, 2=medium, 3=spicy
  order           Int           @default(0)

  set PunishmentSet @relation(fields: [setId], references: [id], onDelete: Cascade)
}

enum GameType {
  DICE_COMPARE
  ROCK_PAPER_SCISSORS
  ROULETTE
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
}

enum MemberRole {
  PLAYER
  SPECTATOR
}
